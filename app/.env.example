# ============================================================
# Vexiajuris Guard — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.
# ============================================================

# --- Supabase (obrigatório) ---
# Encontre em: supabase.com → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Conexão da aplicação — usa o papel restrito `vexiajuris_app` (migration 20260706163639),
# sem BYPASSRLS e sem UPDATE/DELETE/TRUNCATE na trilha. NUNCA aponte para o usuário `postgres`
# aqui fora de dev local efêmero.
# IMPORTANTE: a migration cria vexiajuris_app com a senha 'change_me_before_activating' — é só
# para o Supabase local (efêmero, recriado a cada `supabase start`). Antes de apontar
# DATABASE_URL para qualquer banco real/compartilhado (Supabase cloud), rode manualmente
# `ALTER ROLE vexiajuris_app WITH PASSWORD '<segredo forte gerado por você>';` e use esse
# valor aqui — nunca a senha do arquivo de migration.
# Use o modo "Transaction" (porta 6543) na Vercel para suporte a serverless
DATABASE_URL=postgresql://vexiajuris_app.SEU_PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Conexão de bootstrap — SÓ para onboarding.createOrg (criação de organização nova, que
# ainda não tem org_id para satisfazer a RLS, e precisa checar unicidade de e-mail entre
# todas as orgs). É a ÚNICA rota que deveria usar credencial elevada; nenhuma outra usa isso.
BOOTSTRAP_DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- DATAJUD/CNJ (obrigatório para o validador de citações consultar processos) ---
# Chave pública documentada pelo CNJ (Resolução 331/2020): https://datajud-wiki.cnj.jus.br/api-publica/
DATAJUD_API_KEY=
