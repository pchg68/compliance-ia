# ============================================================
# JurisOS Guard — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.
# ============================================================

# --- Supabase (obrigatório) ---
# Encontre em: supabase.com → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Conexão direta ao PostgreSQL (Supabase → Settings → Database → Connection string → URI)
# Use o modo "Transaction" (porta 6543) na Vercel para suporte a serverless
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
